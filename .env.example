APP_NAME="ADA Co-OS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ── Versiyon ──────────────────────────────
APP_VERSION=3.0
APP_VERSION_NOTE="ADA Co-OS — AI Destekli KOBİ İşletme Yönetim Platformu"

# ── Locale ────────────────────────────────
APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# ── Session ───────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Services ──────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

# ── Mail ──────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AI (NVIDIA API) ───────────────────────
# AI_PROVIDER=nvidia
# NVIDIA_API_KEY=
# NVIDIA_MODEL=
# AI_DAILY_TOKEN_LIMIT=100000

# ── Vite ──────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
